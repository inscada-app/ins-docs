---
import SidebarSublist from '@astrojs/starlight/components/SidebarSublist.astro';
import MobileMenuFooter from 'virtual:starlight/components/MobileMenuFooter';
import VersionSwitcher from './VersionSwitcher.astro';

const { sidebar } = Astro.locals.starlightRoute;

const match = Astro.url.pathname.match(/\/(jdk\d+)(\/|$)/);
const activeVersion = match ? match[1] : 'jdk11';

function containsVersion(entry, v) {
	if (entry.type === 'link') return entry.href.includes(`/${v}/`);
	if (entry.type === 'group') return entry.entries.some((e) => containsVersion(e, v));
	return false;
}

function filterTree(entries, v) {
	return entries
		.filter((e) => containsVersion(e, v))
		.map((e) => (e.type === 'group' ? { ...e, entries: filterTree(e.entries, v) } : e));
}

function flattenOpenApiWrapper(entries) {
	return entries.flatMap((e) => {
		if (e.type !== 'group') return [e];
		const flatChildren = flattenOpenApiWrapper(e.entries);
		const isRestApiRoot = e.label === 'REST API';
		if (!isRestApiRoot) return [{ ...e, entries: flatChildren }];
		const unwrapped = flatChildren.flatMap((child) => {
			if (child.type === 'group' && child.entries.some((c) => c.type === 'group')) {
				return child.entries;
			}
			return [child];
		});
		return [{ ...e, entries: unwrapped }];
	});
}

const filtered = flattenOpenApiWrapper(filterTree(sidebar, activeVersion));
---

<VersionSwitcher activeVersion={activeVersion} />

<SidebarSublist sublist={filtered} />

<div class="md:sl-hidden">
	<MobileMenuFooter />
</div>
